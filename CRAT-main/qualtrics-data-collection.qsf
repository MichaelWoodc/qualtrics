,"TertiaryAttribute":null,"Payload":{"Flow":[{"ID":"BL_9tRzPcdTkgbi7fU","Type":"Standard","FlowID":"FL_3"}],"Properties":{"Count":3},"FlowID":"FL_1","Type":"Root"}},{"SurveyID":"SV_5AdKhoqBgfRP394","Element":"PL","PrimaryAttribute":"Preview Link","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"PreviewType":"Brand","PreviewID":"b7f2cf22-8381-4298-a013-57a2cfe0519c"}},{"SurveyID":"SV_5AdKhoqBgfRP394","Element":"PROJ","PrimaryAttribute":"CORE","SecondaryAttribute":null,"TertiaryAttribute":"1.1.0","Payload":{"ProjectCategory":"CORE","SchemaVersion":"1.1.0"}},{"SurveyID":"SV_5AdKhoqBgfRP394","Element":"QC","PrimaryAttribute":"Survey Question Count","SecondaryAttribute":"60","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_5AdKhoqBgfRP394","Element":"RS","PrimaryAttribute":"RS_3awDEbHPiVBRgZ8","SecondaryAttribute":"Default Response Set","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_5AdKhoqBgfRP394","Element":"SCO","PrimaryAttribute":"Scoring","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"ScoringCategories":[],"ScoringCategoryGroups":[],"ScoringSummaryCategory":null,"ScoringSummaryAfterQuestions":0,"ScoringSummaryAfterSurvey":0,"DefaultScoringCategory":null,"AutoScoringCategory":null}},{"SurveyID":"SV_5AdKhoqBgfRP394","Element":"SO","PrimaryAttribute":"Survey Options","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"BackButton":"false","SaveAndContinue":"true","SurveyProtection":"PublicSurvey","BallotBoxStuffingPrevention":"false","NoIndex":"Yes","SecureResponseFiles":"true","SurveyExpiration":"None","SurveyTermination":"DefaultMessage","Header":"","Footer":"","ProgressBarDisplay":"None","PartialData":"+1 week","ValidationMessage":"","PreviousButton":"","NextButton":"","SurveyTitle":"Qualtrics Survey | Qualtrics Experience Management","SkinLibrary":"georgiasouthern","SkinType":"templated","Skin":{"brandingId":"6216604264","templateId":"*base","overrides":null},"NewScoring":1,"SurveyMetaDescription":"The most powerful, simple and trusted way to gather experience data. Start your journey to experience management and try a free account today.","SurveyName":"custom-1q-form","ProtectSelectionIds":true}},{"SurveyID":"SV_5AdKhoqBgfRP394","Element":"SQ","PrimaryAttribute":"QID1323248576","SecondaryAttribute":"Question-1","TertiaryAttribute":null,"Payload":{"QuestionText":"Question-1","DefaultChoices":false,"QuestionType":"TE","Selector":"FORM","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Question-1","Choices":{"1":{"Display":"Q1.1-RESPONSE"},"2":{"Display":"Q1.1-REACTION-TIME"},"3":{"Display":"Q1.1-TYPING-TIME"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionText_Unsafe":"Question-1","DataExportTag":"Q1.1","QuestionID":"QID1323248576","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function () {\n\n\/\/ qthis.hideNextButton();   \/\/ Removed \u2014 Next button stays visible\nconst qthis = this;\n\n\/* ============================================================\n   FULLSCREEN OVERLAY\n   ============================================================ *\/\nconst overlay = document.createElement(\"div\");\noverlay.style.position = \"fixed\";\noverlay.style.top = \"0\";\noverlay.style.left = \"0\";\noverlay.style.width = \"100vw\";\noverlay.style.height = \"100vh\";\noverlay.style.background = \"#111\";\noverlay.style.color = \"#fff\";\noverlay.style.display = \"flex\";\noverlay.style.flexDirection = \"column\";\noverlay.style.alignItems = \"center\";\noverlay.style.justifyContent = \"center\";\noverlay.style.fontFamily = \"Arial\";\noverlay.style.zIndex = \"99999\";\noverlay.tabIndex = -1;   \/\/ Make overlay focusable\ndocument.body.appendChild(overlay);\n\n\/* ============================================================\n   EXPERIMENT SETTINGS\n   ============================================================ *\/\nconst WORD_TIME = 15000;\nconst TYPE_TIME = 7000;\nconst FIXATION_TIME = 500;\n\nlet problems = [];\nlet trialIndex = 0;\nlet reactionStart = 0;\nlet firstKeyTime = null;\n\n\/* ============================================================\n   DISPLAY STRUCTURE\n   ============================================================ *\/\n\nconst experimentWrapper = document.createElement(\"div\");\nexperimentWrapper.style.display = \"flex\";\nexperimentWrapper.style.flexDirection = \"column\";\nexperimentWrapper.style.alignItems = \"center\";\nexperimentWrapper.style.justifyContent = \"center\";\nexperimentWrapper.style.height = \"100%\";\nexperimentWrapper.style.width = \"100%\";\noverlay.appendChild(experimentWrapper);\n\nconst wordContainer = document.createElement(\"div\");\nwordContainer.style.height = \"200px\";\nwordContainer.style.display = \"flex\";\nwordContainer.style.flexDirection = \"column\";\nwordContainer.style.alignItems = \"center\";\nwordContainer.style.justifyContent = \"center\";\nwordContainer.style.marginBottom = \"40px\";\nexperimentWrapper.appendChild(wordContainer);\n\nconst fixation = document.createElement(\"div\");\nfixation.style.fontSize = \"80px\";\nfixation.style.display = \"none\";\nfixation.innerHTML = \"+\";\nwordContainer.appendChild(fixation);\n\nconst wordsDiv = document.createElement(\"div\");\nwordsDiv.style.fontSize = \"40px\";\nwordsDiv.style.textAlign = \"center\";\nwordsDiv.style.display = \"none\";\nwordContainer.appendChild(wordsDiv);\n\nconst input = document.createElement(\"input\");\ninput.type = \"text\";\ninput.style.fontSize = \"32px\";\ninput.style.padding = \"10px\";\ninput.style.width = \"350px\";\ninput.style.textAlign = \"center\";\ninput.style.display = \"none\";\ninput.style.background = \"#222\";\ninput.style.color = \"#fff\";\ninput.style.border = \"2px solid #fff\";\nwordContainer.appendChild(input);\n\n\/* ============================================================\n   PROGRESS BAR\n   ============================================================ *\/\n\nconst barContainer = document.createElement(\"div\");\nbarContainer.style.height = \"40px\";\nbarContainer.style.display = \"flex\";\nbarContainer.style.alignItems = \"center\";\nbarContainer.style.justifyContent = \"center\";\nexperimentWrapper.appendChild(barContainer);\n\nconst barOuter = document.createElement(\"div\");\nbarOuter.style.width = \"22vw\";\nbarOuter.style.height = \"20px\";\nbarOuter.style.border = \"2px solid #fff\";\nbarOuter.style.visibility = \"visible\";\nbarContainer.appendChild(barOuter);\n\nconst barInner = document.createElement(\"div\");\nbarInner.style.height = \"100%\";\nbarInner.style.width = \"100%\";\nbarInner.style.background = \"#fff\";\nbarInner.style.transition = \"width .1s linear\";\nbarOuter.appendChild(barInner);\n\nfunction updateBar(timeLeft,total){\n    barInner.style.width = (timeLeft\/total*100)+\"%\";\n}\n\nfunction resetBar() {\n    barInner.style.transition = \"none\";\n    barInner.style.width = \"100%\";\n    void barInner.offsetWidth;\n    barInner.style.transition = \"width .1s linear\";\n}\n\n\/* ============================================================\n   FORCE QUALTRICS TO RENDER ALL QUESTIONS\n   ============================================================ *\/\n\nfunction forceRenderAllQuestions() {\n    return new Promise(resolve => {\n        window.scrollTo(0, document.body.scrollHeight);\n        setTimeout(() => {\n            window.scrollTo(0, 0);\n            setTimeout(resolve, 200);\n        }, 200);\n    });\n}\n\n\/* ============================================================\n   DYNAMIC QID DETECTION\n   ============================================================ *\/\n\nlet responseRows = [];\n\nfunction detectResponseRows() {\n\n    const allQIDs = Array.from(document.querySelectorAll(\"[id^='QID']\"))\n        .map(el => el.id)\n        .filter(id => \/^QID\\d+$\/.test(id))\n        .map(id => ({\n            id,\n            num: parseInt(id.replace(\"QID\", \"\"), 10)\n        }))\n        .sort((a, b) => a.num - b.num);\n\n    responseRows = [];\n\n    for (const q of allQIDs) {\n        const qElem = document.getElementById(q.id);\n        if (!qElem) continue;\n\n        const inputs = qElem.querySelectorAll(\"input[type='text']\");\n        if (inputs.length === 3) {\n            responseRows.push(inputs);\n        }\n    }\n\n    console.log(\"Detected\", responseRows.length, \"rows.\");\n}\n\n\/* ============================================================\n   STORE RESPONSES LOCALLY\n   ============================================================ *\/\nlet savedResponses = [];\n\n\/* ============================================================\n   WRITE TO QUALTRICS\n   ============================================================ *\/\nlet qualIndex = 0;\n\nfunction writeToQualtrics(resp, rt, tt) {\n\n    savedResponses.push({resp, rt, tt});\n\n    if (!responseRows[qualIndex]) {\n        console.error(\"No row for index\", qualIndex);\n        return;\n    }\n\n    const inputs = responseRows[qualIndex];\n    inputs[0].value = resp;\n    inputs[1].value = rt;\n    inputs[2].value = tt;\n\n    qualIndex++;\n}\n\n\/* ============================================================\n   FIXATION PHASE\n   ============================================================ *\/\nfunction startFixation() {\n    resetBar();\n    barOuter.style.visibility = \"hidden\";\n\n    wordsDiv.style.display = \"none\";\n    input.style.display = \"none\";\n    fixation.style.display = \"block\";\n\n    setTimeout(() => {\n        fixation.style.display = \"none\";\n        startWordPhase();\n    }, FIXATION_TIME);\n}\n\n\/* ============================================================\n   WORD PHASE\n   ============================================================ *\/\nfunction startWordPhase(){\n\n overlay.focus();   \/\/ Ensure key events always go to overlay\n\n if(trialIndex >= problems.length){\n   finishExperiment();\n   return;\n }\n\n resetBar();\n barOuter.style.visibility = \"visible\";\n\n const p = problems[trialIndex];\n wordsDiv.innerHTML = p.words.join(\"<br>\");\n wordsDiv.style.display = \"block\";\n input.style.display = \"none\";\n input.value = \"\";\n reactionStart = performance.now();\n firstKeyTime = null;\n\n let timeLeft = WORD_TIME\/1000;\n\n const timer = setInterval(function(){\n  timeLeft -= 0.1;\n  updateBar(timeLeft,WORD_TIME\/1000);\n  if(timeLeft<=0){\n   clearInterval(timer);\n   nextTrial(\"\",\"\",\"\");\n  }\n },100);\n\n function keyListener(e){\n  if(e.key === \"Enter\") return;\n  e.preventDefault();\n\n  clearInterval(timer);\n  document.removeEventListener(\"keydown\",keyListener);\n  firstKeyTime = performance.now() - reactionStart;\n  startTypingPhase(e.key);\n }\n\n document.addEventListener(\"keydown\",keyListener);\n}\n\n\/* ============================================================\n   TYPING PHASE\n   ============================================================ *\/\nfunction startTypingPhase(firstChar){\n resetBar();\n barOuter.style.visibility = \"visible\";\n\n wordsDiv.style.display = \"none\";\n fixation.style.display = \"none\";\n\n input.style.display = \"block\";\n input.value = firstChar || \"\";\n input.focus();\n input.setSelectionRange(input.value.length,input.value.length);\n\n const typingStart = performance.now();\n let timeLeft = TYPE_TIME\/1000;\n\n const timer = setInterval(function(){\n  timeLeft -= 0.1;\n  updateBar(timeLeft,TYPE_TIME\/1000);\n  if(timeLeft<=0){\n   clearInterval(timer);\n   nextTrial(input.value,Math.round(firstKeyTime),Math.round(performance.now()-typingStart));\n  }\n },100);\n\n function enterListener(e){\n  if(e.key === \"Enter\"){\n   clearInterval(timer);\n   document.removeEventListener(\"keydown\",enterListener);\n   nextTrial(input.value,Math.round(firstKeyTime),Math.round(performance.now()-typingStart));\n  }\n }\n\n document.addEventListener(\"keydown\",enterListener);\n}\n\n\/* ============================================================\n   SAVE + NEXT TRIAL\n   ============================================================ *\/\nfunction nextTrial(response,rt,tt){\n\n writeToQualtrics(response,rt,tt);\n\n setTimeout(() => {\n     trialIndex++;\n     startFixation();\n }, 50);\n}\n\n\/* ============================================================\n   FINISH\n   ============================================================ *\/\nfunction finishExperiment(){\n\n if (overlay && overlay.parentNode) {\n     overlay.parentNode.removeChild(overlay);\n }\n\n setTimeout(() => {\n\n     for (let i = 0; i < savedResponses.length; i++) {\n         if (!responseRows[i]) continue;\n         const {resp, rt, tt} = savedResponses[i];\n         const inputs = responseRows[i];\n         inputs[0].value = resp;\n         inputs[1].value = rt;\n         inputs[2].value = tt;\n     }\n\n     qthis.clickNextButton();   \/\/ AUTO\u2011ADVANCE ENABLED\n\n }, 50);\n}\n\n\/* ============================================================\n   LOAD PROBLEMS + FORCE RENDER + DETECT ROWS + START\n   ============================================================ *\/\nfetch(\"https:\/\/raw.githubusercontent.com\/MichaelWoodc\/qualtrics\/main\/CRAT-main\/full_cra_problems.json\")\n.then(resp => resp.json())\n.then(data => {\n\n    if (data && Array.isArray(data.problems)) {\n        problems = data.problems.filter(p =>\n            p &&\n            Array.isArray(p.words) &&\n            p.words.length === 3\n        );\n    }\n\n})\n.catch(err => {\n    console.error(\"Failed to load GitHub JSON:\", err);\n})\n.finally(() => {\n\n    forceRenderAllQuestions().then(() => {\n        detectResponseRows();\n        startFixation();\n    });\n\n});\n\n});"}},{"SurveyID":"SV_5AdKhoqBgfRP394","Element":"SQ","PrimaryAttribute":"QID1323248577","SecondaryAttribute":"Question-2","TertiaryAttribute":null,"Payload":{"QuestionText":"Question-2","DefaultChoices":false,"QuestionType":"TE","Selector":"FORM","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Question-2","Choices":{"1":{"Display":"Q1.2-RESPONSE"},"2":{"Display":"Q1.2-REACTION-TIME"},"3":{"Display":"Q1.2-TYPING-TIME"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionText_Unsafe":"Question-1","DataExportTag":"Q1.2","QuestionID":"QID1323248577"}},{"SurveyID":"SV_5AdKhoqBgfRP394","Element":"SQ","PrimaryAttribute":"QID1323248578","SecondaryAttribute":"Question-3","TertiaryAttribute":null,"Payload":{"QuestionText":"Question-3","DefaultChoices":false,"QuestionType":"TE","Selector":"FORM","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Question-3","Choices":{"1":{"Display":"Q1.3-RESPONSE"},"2":{"Display":"Q1.3-REACTION-TIME"},"3":{"Display":"Q1.3-TYPING-TIME"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionText_Unsafe":"Question-1","DataExportTag":"Q1.3","QuestionID":"QID1323248578"}},{"SurveyID":"SV_5AdKhoqBgfRP394","Element":"SQ","PrimaryAttribute":"QID1323248579","SecondaryAttribute":"Question-4","TertiaryAttribute":null,"Payload":{"QuestionText":"Question-4","DefaultChoices":false,"QuestionType":"TE","Selector":"FORM","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Question-4","Choices":{"1":{"Display":"Q1.4-RESPONSE"},"2":{"Display":"Q1.4-REACTION-TIME"},"3":{"Display":"Q1.4-TYPING-TIME"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF"}},"GradingData":[],"Language":[],"NextChoiceId":4,"Next